{
  "name": "light-html-editor",
  "version": "0.1.0",
  "description": "Lightweight embeddable HTML page editor — edit text and styles in existing HTML documents",
  "keywords": ["html-editor", "wysiwyg", "page-editor", "landing-page", "no-code"],
  "license": "MIT",
  "type": "module",
  "main": "./dist/light-html-editor.umd.js",
  "module": "./dist/light-html-editor.es.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/light-html-editor.es.js",
      "require": "./dist/light-html-editor.umd.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.build.json && vite build",
    "preview": "vite preview"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vite-plugin-dts": "^3.9.0"
  }
}
